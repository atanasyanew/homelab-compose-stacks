# PostgreSQL settings for nocodb-db.
POSTGRES_DB=nocodb
POSTGRES_USER=nocodb
POSTGRES_PASSWORD=change-me-nocodb

# NocoDB external database connection string.
NC_DB=pg://nocodb-db:5432?u=nocodb&p=change-me-nocodb&d=nocodb

# Required for stable auth sessions; replace with a long random value.
NC_AUTH_JWT_SECRET=change-this-to-a-long-random-secret
